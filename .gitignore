# ===============================
# Unity .gitignore
# ===============================

# Unity 自動生成フォルダ（巨大・再生成可能）
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Asset Store からのインポートキャッシュ
/[Aa]sset[Ss]tore[Tt]ools/

# Visual Studio / Rider キャッシュ
.vs/
.vscode/
.idea/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D 生成メタデータ
*.pidb.meta
*.pdb.meta
*.mdb.meta

# OS 生成ファイル
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Crashlytics
crashlytics-build.properties
sysinfo.txt

# Builds（ビルド成果物）
*.apk
*.aab
*.unitypackage
*.app
*.ipa

# Gradle
/[Aa]ndroid/
*.gradle
.gradle/

# TextMeshPro（Essentials は各自インポート）
/Assets/TextMesh Pro/
